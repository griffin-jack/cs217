## HLS SP synthesis script
## Generated for stage extract
## Vivado mode is Non-project

# Version check
set vv [version -short]
if { [regexp {(\d+)\.(\d+).*} $vv all major minor] } {
  if { ($major < 2020) || ($major == 2020 && $minor < 2) } {
    puts "Vivado version (v${vv}) is not compatible with version used for the Catapult library (v2020.2)."
  }
}
# Reporting settings
puts "-- Requested 4 fractional digits for design 'PEPartition' timing"
puts "-- Requested 4 fractional digits for design 'PEPartition' capacitance"
puts "-- Characterization mode: p2p "

puts "-- Synthesis Timing report: '/home/users/code/cs217/hls/Top/PEPartition/Catapult/PEPartition.v1/vivado_v/timing_summary_synth.rpt' "
puts "-- Synthesis Utilization report: '/home/users/code/cs217/hls/Top/PEPartition/Catapult/PEPartition.v1/vivado_v/utilization_synth.rpt' "
if { ([info exists env(Xilinx_RUN_PNR)] && $env(Xilinx_RUN_PNR) ) || 
     ([info exists env(Xilinx_BITGEN)] && $env(Xilinx_BITGEN) ) } {
